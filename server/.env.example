# Copy to .env and fill in. Loaded via `node --env-file=.env` (Node 20.6+).

# Postgres — same instance as the rest of the app
DATABASE_URL=postgres://postgres:postgres@localhost:5432/familychats

# API port
PORT=3002

# Optional: Expo push security. Set once you enable "Enhanced Security" for
# push in your Expo account. Leave blank otherwise.
EXPO_ACCESS_TOKEN=

# Optional: powers AI Chat Summary + AI Search (src/ai.js). Without it, those
# two endpoints respond 503 with a clear "AI is not configured" error —
# everything else in the app works fine. Get a key at console.anthropic.com.
ANTHROPIC_API_KEY=
